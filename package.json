{
  "name": "image-gallery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "concurrently --kill-others \"vite\" \"tsx watch src/server/server.ts\"",
    "dev:next": "concurrently --kill-others \"vite --mode next\" \"tsx watch src/server/server.ts\"",
    "dev:legacy": "concurrently --kill-others \"vite --mode legacy\" \"tsx watch src/server/server.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.web-next.json",
    "typecheck:next": "tsc --noEmit -p tsconfig.web-next.json && vite build --mode next",
    "test:web-next": "vitest run",
    "test:metadata": "tsx --test src/server/metadata-definitions.test.ts src/server/metadata-name.test.ts src/server/dimensions.test.ts src/server/previews.test.ts src/server/admin.test.ts",
    "test:name-generation": "node --test gallery-name-generator.test.mjs gallery-metadata-context.test.mjs",
    "test:batch": "node --test process-gallery-batch.test.mjs",
    "test:cleanup": "node --test clear-gallery-data.test.mjs",
    "build:web": "vite build",
    "build:web:next": "vite build --mode next",
    "build:web:legacy": "vite build --mode legacy",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run clean && npm run build:web && npm run build:server",
    "process-batch": "node process-gallery-batch.mjs",
    "rename-existing": "node process-gallery-batch.mjs --rename-existing",
    "backfill-name-metadata": "node process-gallery-batch.mjs --backfill-name-metadata",
    "process-new-schema": "tsx src/tools/process-new-schema.ts",
    "process-new-name-schema": "node process-new-name-schema.mjs",
    "remove-image": "node remove-gallery-image.mjs",
    "rebuild-previews": "tsx src/tools/rebuild-previews.ts",
    "clear-untagged": "node clear-untagged-images.mjs",
    "clear-generated-artifacts": "node clear-gallery-data.mjs --generated-only",
    "clear-gallery": "node clear-gallery-data.mjs --all",
    "scan-for-duplicates": "node scan-for-duplicates.mjs",
    "start": "node dist/server/server/server.js"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "concurrently": "^9.2.4",
    "svelte": "^5.56.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
