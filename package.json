{
  "name": "image-gallery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "concurrently --kill-others \"vite\" \"tsx watch src/server/server.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run clean && npm run build:web && npm run build:server",
    "process-batch": "node process-gallery-batch.mjs",
    "rename-existing": "node process-gallery-batch.mjs --rename-existing",
    "scan-for-duplicates": "node scan-for-duplicates.mjs",
    "start": "node dist/server/server/server.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
