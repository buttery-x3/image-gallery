# Directory containing the images and GIFs to display.
GALLERY_DIR=./gallery

# Branding used in the page heading, browser metadata, and social previews.
# GALLERY_TITLE=Image Gallery
# GALLERY_DESCRIPTION=A simple private image gallery.

# Full public gallery URL, including any path prefix. When set, the build adds
# absolute canonical and social-preview URLs. Keep the real value in .env.
# SITE_URL=https://gallery.example.com/

# Generated GIF and PNG previews are stored outside GALLERY_DIR; original gallery files are never changed.
PREVIEW_CACHE_DIR=./.cache/previews

# Optional: rename incoming batches with long Japanese-inspired fantasy names.
# BATCH_NAME_STYLE=japanese-fantasy

# PM2 process restarted by deploy.sh; set this separately for each instance.
PM2_APP_NAME=image-gallery

# Keep the app private behind Caddy by listening on loopback only.
HOST=127.0.0.1
PORT=8080
