# Directory containing the images and GIFs to display.
GALLERY_DIR=./gallery

# Full public gallery URL, including any path prefix. When set, the build adds
# absolute canonical and social-preview URLs. Keep the real value in .env.
# SITE_URL=https://gallery.example.com/

# Optional private support/donation embed. The committed gallery configuration
# disables it by default. Keep the real HTML fragment under the ignored
# .private directory and explicitly enable it only for your deployment.
# ENABLE_SUPPORT_EMBED=true
# SUPPORT_EMBED_FILE=.private/support-embed.html
# SUPPORT_SCRIPT_ORIGINS=https://example-support-provider.invalid

# Generated GIF/PNG previews and GIF first-frame posters are stored outside GALLERY_DIR; originals are never changed.
PREVIEW_CACHE_DIR=./.cache/previews

# Derived intrinsic dimensions used by the virtual masonry layout. This file must also remain outside GALLERY_DIR.
DIMENSION_CACHE_PATH=./.cache/catalog-dimensions.json

# PM2 process restarted by deploy.sh; set this separately for each instance.
# PM2_APP_NAME=your-gallery-process

# Keep the app private behind Caddy by listening on loopback only.
HOST=127.0.0.1
PORT=8080

# Optional admin deletion access. Store only an Argon2id encoded password hash.
# ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# File that receives one absolute local image path for each explicit-content
# report. It defaults to ./reported-image-paths.txt.
# REPORT_LIST_PATH=./reported-image-paths.txt
